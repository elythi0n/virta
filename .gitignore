# Build output
/dist/
/bin/
*.exe

# Test / coverage
*.test
coverage.out
coverage.txt

# Local data / secrets (never commit)
*.db
*.db-wal
*.db-shm
.env
.env.*
!.env.example

# Internal planning docs — kept locally, not part of the published repo.
# Code comments are written to be self-contained, so nothing in the codebase depends on these.
/docs/
/tracker.md

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Node (frontends)
node_modules/
dist-ssr/
frontends/*/dist/
frontends/*/.vite/
*.tsbuildinfo

# Desktop shell (Wails) build inputs/outputs; the .gitkeep placeholders are kept.
frontends/desktop/build/
frontends/desktop/assets/*
!frontends/desktop/assets/.gitkeep
frontends/desktop/bin/*
!frontends/desktop/bin/.gitkeep
