# Build output
/dist/
/bin/
*.exe

# Test / coverage
*.test
coverage.out
coverage.txt

# Local data / secrets (never commit)
*.db
*.db-wal
*.db-shm
.env
.env.*
!.env.example

# Internal planning docs — kept locally, not part of the published repo.
# Code comments are written to be self-contained, so nothing in the codebase depends on these.
/docs/
/tracker.md

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Node (frontends)
node_modules/
dist-ssr/
frontends/*/dist/
frontends/*/.vite/
*.tsbuildinfo

# Desktop shell (Electron) staged build inputs; the .gitkeep placeholders are kept. The web build
# and the virtad binary are copied in by `make app`; the icon is copied from the ui-kit logo.
frontends/desktop/resources/web/*
!frontends/desktop/resources/web/.gitkeep
frontends/desktop/resources/bin/*
!frontends/desktop/resources/bin/.gitkeep
frontends/desktop/build/icon.png

# Web UI staged into the daemon for embedding; the .gitkeep placeholder is kept.
internal/webui/dist/*
!internal/webui/dist/.gitkeep
