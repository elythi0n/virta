{
  "$schema": "virta-tokens/1",
  "_note": "Single source of truth for the design system. Generated outputs (tokens.css, tokens.ts) are produced by cmd/tokengen; edit this file, then run `make tokens`.",
  "font": {
    "ui": "Geist Variable",
    "mono": "Geist Mono Variable"
  },
  "type": {
    "ui": { "size": 13, "line": 20, "weight": 400 },
    "body": { "size": 14, "line": 22, "weight": 400 },
    "meta": { "size": 11, "line": 16, "weight": 400 },
    "title": { "size": 16, "line": 24, "weight": 600 },
    "heading": { "size": 14, "line": 20, "weight": 600 },
    "mono": { "size": 12, "line": 18, "weight": 400 },
    "chat-tiny": { "size": 12, "line": 17, "weight": 400 },
    "chat-compact": { "size": 13, "line": 19, "weight": 400 },
    "chat-cozy": { "size": 14, "line": 21, "weight": 400 },
    "chat-comfortable": { "size": 15, "line": 23, "weight": 400 },
    "chat-large": { "size": 16, "line": 25, "weight": 400 }
  },
  "space": [2, 4, 8, 12, 16, 24, 32],
  "radius": { "sm": 5, "md": 6, "lg": 8 },
  "motion": { "fast": 120, "base": 160 },
  "platform": {
    "twitch": "#9146FF",
    "kick": "#53FC18",
    "youtube": "#FF0000"
  },
  "brand": {
    "anthropic": "#D4620A",
    "openai": "#10A37F"
  },
  "themes": {
    "graphite-dark": {
      "appearance": "dark",
      "color": {
        "bg-0": "#0E0F12",
        "bg-1": "#15171C",
        "bg-2": "#1C1F26",
        "line": "#262A33",
        "text-0": "#E8EAF0",
        "text-1": "#9AA1AE",
        "text-2": "#5C6370",
        "accent": "#5B8CFF",
        "ok": "#3FB950",
        "warn": "#D29922",
        "danger": "#F85149",
        "highlight-bg": "#3D2E12",
        "highlight-rail": "#D29922",
        "plat-x": "#E7E9EA",
        "scrollbar-thumb": "#2F333D",
        "scrollbar-thumb-hover": "#3D4350"
      }
    },
    "light": {
      "appearance": "light",
      "color": {
        "bg-0": "#FAFBFC",
        "bg-1": "#F1F3F5",
        "bg-2": "#E7EAED",
        "line": "#D5D9DF",
        "text-0": "#1A1D23",
        "text-1": "#5C6370",
        "text-2": "#7C8492",
        "accent": "#3B6FE0",
        "ok": "#1A7F37",
        "warn": "#9A6700",
        "danger": "#CF222E",
        "highlight-bg": "#FFF4D6",
        "highlight-rail": "#9A6700",
        "plat-x": "#0F1419",
        "scrollbar-thumb": "#C7CDD4",
        "scrollbar-thumb-hover": "#AEB5BF"
      }
    }
  }
}
