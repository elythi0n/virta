# Virta environment configuration. Copy to .env and fill in the required values.
# Required values are marked with ":?".

# ---- Required ----

# A long random secret used to authenticate API clients and the embedded SPA.
# Generate with: openssl rand -hex 32
VIRTA_TOKEN=change-this-to-a-long-random-secret

# ---- Storage ----

# Use "postgres" for server deployments (recommended); "sqlite" for local installs.
VIRTA_STORAGE=postgres

# Postgres connection string (only when VIRTA_STORAGE=postgres).
# In docker compose this is auto-set to point at the db service.
VIRTA_DB_DSN=postgres://virta:virta@db:5432/virta?sslmode=disable

# Postgres database password. Change before deploying; must match VIRTA_DB_DSN.
POSTGRES_PASSWORD=virta

# ---- Hosted multi-user mode ----

# Set to 1 to enable user registration, login, and per-user workspaces.
# Leave 0 for a personal single-user install.
VIRTA_HOSTED=0

# ---- Platform OAuth app credentials (optional) ----
# Users can paste their own keys in Settings → Connections; these set the default
# server-side app so users don't need to create their own.

VIRTA_TWITCH_CLIENT_ID=
VIRTA_KICK_CLIENT_ID=
VIRTA_KICK_CLIENT_SECRET=

# ---- Optional services ----

# Meilisearch master key (only if you uncomment the meilisearch service in docker-compose.yml).
# MEILI_MASTER_KEY=change-this-to-a-random-key

# ---- Networking ----

# Listen address. 0.0.0.0 is correct for a Docker container; 127.0.0.1 for local-only.
VIRTA_ADDR=0.0.0.0:8344
